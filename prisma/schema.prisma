generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model M_STORE {
  store_id     Int            @id @default(autoincrement())
  store_name   String
  branch_name  String?
  address      String?
  created_user String
  created_time DateTime          @default(now())
  accountings  T_ACCOUNTING[]
  unit_prices  T_UNIT_PRICE[]
}

model M_SUBJECT {
  subject_id           Int            @id @default(autoincrement())
  major_cd             Int
  middle_cd            Int?
  minor_cd             Int?
  DC_cd                String?
  subject_name         String
  is_graph_enabled     Int            @default(0)
  unit                 String?        @default("個")
  quantity_of_per_unit Int?           @default(1)
  created_user         String
  created_time         DateTime          @default(now())
  accountings          T_ACCOUNTING[]

  @@unique([major_cd, middle_cd, minor_cd], map: "sqlite_autoindex_M_SUBJECT_1")
}

model T_UNIT_PRICE {
  major_cd     Int
  middle_cd    Int
  minor_cd     Int
  store_id     Int
  base_date    Int
  unit_price   Float
  created_user String
  created_time DateTime   @default(now())
  store        M_STORE @relation(fields: [store_id], references: [store_id])

  @@id([major_cd, middle_cd, minor_cd, store_id, base_date])
  @@index([major_cd, middle_cd, minor_cd, store_id, base_date], map: "IDX_UNIT_PRICE")
}

model T_ACCOUNTING {
  account_id   Int        @id @default(autoincrement())
  seq          Int
  major_cd     Int
  middle_cd    Int?
  minor_cd     Int?
  store_id     Int
  base_date    Int
  DC_cd        String?
  quantity     Int
  amount       Int
  created_user String?
  created_time DateTime   @default(now())
  store        M_STORE    @relation(fields: [store_id], references: [store_id])
  subject      M_SUBJECT? @relation(fields: [major_cd, middle_cd, minor_cd], references: [major_cd, middle_cd, minor_cd])

  @@index([major_cd, middle_cd, minor_cd])
  @@index([store_id])
}
