<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>買い物登録</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
  <style>
    .offcanvas-body a {
      color: #fff;
      display: flex;
      align-items: center;
      padding: 12px 20px;
      text-decoration: none;
      font-weight: 500;
      transition: all 0.2s;
    }
    .offcanvas-body a i { margin-right: 10px; font-size: 1.2rem; }
    .offcanvas-body a:hover { background-color: #444; }
    .offcanvas-body .logout { color: #ff5c5c !important; margin-top: 20px; }
    .card-body { background-color: #fff; border-radius: 12px; }
  </style>
</head>
<body class="bg-light">

<nav class="navbar navbar-dark bg-dark fixed-top">
  <div class="container-fluid">
    <button class="btn btn-dark" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasMenu">☰</button>
    <span class="navbar-brand ms-3">買い物登録</span>
  </div>
</nav>

<div class="offcanvas offcanvas-start bg-dark text-white" tabindex="-1" id="offcanvasMenu">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title">Expenses</h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
  </div>
  <div class="offcanvas-body d-flex flex-column p-0">
    <a href="/menu"><i class="bi bi-house-door"></i> メインメニュー</a>
    <a href="/chart"><i class="bi bi-graph-up"></i> 単価グラフ</a>
    <a href="/shopping_register"><i class="bi bi-pencil-square"></i> 買い物登録</a>
    <a href="/check_cost"><i class="bi bi-pie-chart-fill"></i> 支出確認</a>
    <a href="/logout" class="logout"><i class="bi bi-box-arrow-right"></i> ログアウト</a>
  </div>
</div>

<div class="container my-5 pt-5" width="80%">
  <div class="row justify-content-center">
    <div class="col-lg-10">
      <div class="card shadow">
        <div class="card-body">
          <h5 class="card-title mb-4 text-center">★単価登録★</h5>
          <form id="unitForm">
            <div class="mb-3">
              <label>取引日</label>
              <input type="date" id="baseDate" class="form-control" value="<%= base_data.base_date %>" disabled>
            </div>
            <div class="mb-3">
              <label>店舗</label>
              <input type="text" id="store_name" class="form-control" value="<%= base_data.store_name %>" disabled>
            </div>
            <div class="mb-3">
              <label>支払方法</label>
              <input type="text" id="baseDate" class="form-control" value="<%= base_data.subject_name %>" disabled>
            </div>
            <!-- 商品明細テーブル -->
            <table class="table" id="unitTable">
              <thead>
                <tr>
                  <th colspan="3">商品</th>
                  <th class="w-50">単価</th>
                </tr>
              </thead>
              <tbody>
                <% unitPriseEntries.forEach(entry => { %>
                  <tr class="unitRow">
                    <td>
                      <%= entry.major_subject %>
                    </td>
                    <td>
                      <%= entry.middle_subject %>
                    </td>
                    <td>
                      <%= entry.minor_subject ? entry.minor_subject : '－' %>
                    </td>
                    <td>
                      <input type="text" class="form-control w-75 unit_price" placeholder="単価を入力" value="<%= entry.unit_price ? entry.unit_price : 0 %>">
                    </td>
                    <input type="hidden" class="major_cd" value="<%= entry.major_cd %>">
                    <input type="hidden" class="middle_cd" value="<%= entry.middle_cd %>">
                    <input type="hidden" class="minor_cd" value="<%= entry.minor_cd ? entry.minor_cd : null %>">
                    <input type="hidden" class="minor_subject" value="<%= entry.minor_subject %>">
                  </tr>
                <% }) %>
              </tbody>
            </table>

            <button type="submit" class="btn btn-primary w-100">登録</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const unitTable = document.getElementById('unitTable').querySelector('tbody');

// 送信
document.getElementById('unitForm').addEventListener('submit', async e => {
  e.preventDefault();
  const rows = Array.from(unitTable.querySelectorAll('tr'));
  const unit_list = rows.map(row => {
    const major_cd = row.querySelector('.major_cd')?.value ?? null;
    const middle_cd = row.querySelector('.middle_cd')?.value ?? null;
    const minor_cd = row.querySelector('.minor_cd')?.value ?? null;
    const minor_subject = row.querySelector('.minor_subject')?.value ?? null;
    const unit_price = parseFloat(row.querySelector('.unit_price').value) || 0;
    return {
      major_cd : major_cd,
      middle_cd : middle_cd,
      minor_cd : minor_cd,
      minor_subject : minor_subject,
      unit_price : unit_price
    };
  });

  try {
    await axios.post('/api/unit', unit_list);
    window.location.href = '/register_check';
  } catch (err) {
    console.error(err);
    alert('登録に失敗しました');
  }
});
</script>
</body>
</html>
